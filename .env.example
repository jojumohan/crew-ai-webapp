# Core auth + messaging
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Firebase is now the primary backend for auth + messaging
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional legacy/public Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Optional agent + automation integrations
AGENT_URL=http://127.0.0.1:8765
SEED_SECRET=replace-with-seed-secret
GROQ_API_KEY=
SARVAM_API_KEY=

# Optional alternative SQL backend
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/crew_ai_webapp

# Optional push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Optional calendar integrations
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_API_KEY=
CALENDAR_CREATE_SECRET=

# Optional Daily.co calling for legacy routes
DAILY_API_KEY=
